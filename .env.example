# ─────────────────────────────────────────────────────────────────────────────
# La Hacienda — Environment Variables Template
# ─────────────────────────────────────────────────────────────────────────────
#
# HOW TO USE:
#   1. Copy this file:  cp .env.example .env.local
#   2. Fill in your real values in .env.local
#   3. NEVER commit .env.local — it is in .gitignore
#   4. This file (.env.example) IS safe to commit — placeholder values only
#
# WHERE TO GET THESE VALUES:
#   1. Create a Supabase project at https://supabase.com/dashboard
#   2. Go to: Settings → API → "Project URL" and "Project API Keys"
#   3. Go to: Settings → Database → "Connection string"
#      - Use "Transaction Pooler" URI for DATABASE_URL (works with PgBouncer)
#      - Use "Direct Connection" URI for DIRECT_URL (needed for migrations)
#
# NAMING CONVENTION:
#   NEXT_PUBLIC_*  → Safe to expose to the browser (included in client bundle)
#   Everything else → Server-only; never sent to the browser
# ─────────────────────────────────────────────────────────────────────────────

# ── Supabase Project URL ──────────────────────────────────────────────────────
# Public URL of your Supabase project.
# Format: https://<your-project-ref>.supabase.co
# Safe to expose to the browser.
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co

# ── Supabase Anon (Public) Key ────────────────────────────────────────────────
# The "anon" key is used by the browser-side Supabase client.
# It is safe to expose — all access is gated by Row Level Security (RLS) policies.
# Found at: Supabase Dashboard → Settings → API → "anon public"
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# ── Supabase Service Role Key ─────────────────────────────────────────────────
# DANGER: This key BYPASSES all Row Level Security policies.
# Use ONLY in Server Actions for privileged admin operations.
# NEVER expose to the browser or use in Client Components.
# Found at: Supabase Dashboard → Settings → API → "service_role secret"
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# ── Prisma: Transaction Pooler URL (Runtime) ──────────────────────────────────
# Used by Prisma Client at runtime (during `npm run dev` and production).
# This goes through PgBouncer — required for serverless/edge environments.
# Format: postgresql://postgres.[ref]:[password]@aws-0-[region].pooler.supabase.com:6543/postgres
# Found at: Supabase Dashboard → Settings → Database → "Transaction Pooler"
# IMPORTANT: Append ?pgbouncer=true&connection_limit=1 to the URL
DATABASE_URL=postgresql://postgres.[your-ref]:[your-password]@aws-0-us-east-1.pooler.supabase.com:6543/postgres?pgbouncer=true&connection_limit=1

# ── Prisma: Direct Connection URL (Migrations only) ───────────────────────────
# Used ONLY by `prisma migrate dev` and `prisma migrate deploy`.
# Bypasses PgBouncer and connects directly to the database.
# Required because PgBouncer does not support the DDL statements used in migrations.
# Format: postgresql://postgres:[password]@db.[ref].supabase.co:5432/postgres
# Found at: Supabase Dashboard → Settings → Database → "Direct Connection"
DIRECT_URL=postgresql://postgres:[your-password]@db.[your-ref].supabase.co:5432/postgres
